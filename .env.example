# Annual risk-free rate used for Sharpe / Sortino / alpha. Defaults to 0.045 (4.5%).
RISK_FREE_RATE=0.045

# Preferred live market-data source. Free key (no card) at https://twelvedata.com/pricing
# (Free tier: ~800 calls/day). Authenticates per-key, so it works on corporate/VPN
# networks where anonymous Yahoo/Stooq get IP-rate-limited. If unset, the app tries
# Yahoo then Stooq, then deterministic demo data.
TWELVE_DATA_API_KEY=

# LLM for thesis analysis + memo prose (never the math/metrics/verdict/forecasts).
# Any OpenAI-compatible chat-completions endpoint works. If unset, Stochastick
# returns its deterministic rule-based analysis.
#
# RECOMMENDED — GMI Cloud (hackathon partner; 200+ models via one API key):
#   GMI_API_KEY=<your GMI Cloud key>
#   GMI_BASE_URL=https://api.gmi-serving.com/v1
#   GMI_MODEL=<a GMI Cloud model id, e.g. deepseek-ai/DeepSeek-V3 or a Llama/Qwen model>
#
# Alternative — OpenRouter (key starts with sk-or-v1-):
#   GMI_BASE_URL=https://openrouter.ai/api/v1
#   GMI_MODEL=openai/gpt-4o-mini
GMI_API_KEY=
GMI_BASE_URL=
GMI_MODEL=
