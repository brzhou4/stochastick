# Annual risk-free rate used for Sharpe / Sortino / alpha. Defaults to 0.045 (4.5%).
RISK_FREE_RATE=0.045

# Optional: GMI-compatible chat completions endpoint used ONLY to phrase the memo.
# If any of these are missing, ThesisBreak returns a deterministic rule-based memo.
GMI_API_KEY=
GMI_BASE_URL=
GMI_MODEL=
